{
  "expo": {
    "name": "HueMatcher",
    "slug": "huematcher-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF4EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huematcher.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF4EE"
      },
      "package": "com.huematcher.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HueMatcher to access your camera for color analysis photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HueMatcher to access your photo library for color analysis."
        }
      ]
    ]
  }
}