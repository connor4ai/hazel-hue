{
  "expo": {
    "name": "Hazel & Hue",
    "slug": "hazel-hue",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hazelhue",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hazelhue.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Hazel & Hue needs access to your camera to capture a selfie for color analysis.",
        "NSPhotoLibraryUsageDescription": "Hazel & Hue needs access to your photo library to select a photo for color analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6EE"
      },
      "package": "com.hazelhue.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Hazel & Hue to access your camera for color analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hazel & Hue to access your photos for color analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
