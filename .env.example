# Node Environment
NODE_ENV=development
PORT=5000

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/hazelhue

# Redis Configuration (for sessions, caching, and job queues)
# IMPORTANT: Redis is REQUIRED for production deployments
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Stripe Payment Configuration (get from https://stripe.com/docs/keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# OpenAI Configuration (for AI color analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# SendGrid Email Configuration (for result delivery)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@hazelandhue.com

# Admin Panel Configuration
# IMPORTANT: Must be at least 8 characters, 12+ recommended for production
ADMIN_PASSWORD=your_secure_admin_password_min_12_chars

# Optional: Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# Optional: Session Secret (auto-generated if not set)
# IMPORTANT: Set this in production for consistent sessions across restarts
SESSION_SECRET=your_32_character_minimum_session_secret_here

# PRODUCTION DEPLOYMENT CHECKLIST:
# ✓ Use strong passwords (min 12 characters for ADMIN_PASSWORD)
# ✓ Always set REDIS_PASSWORD in production
# ✓ Keep all secrets secure and NEVER commit to git
# ✓ Rotate keys regularly (quarterly recommended)
# ✓ Use production Stripe keys (not test keys)
# ✓ Set up proper DATABASE_URL for production database
# ✓ Configure SENDGRID_FROM_EMAIL with verified domain
# ✓ Generate strong SESSION_SECRET (use: openssl rand -base64 32)